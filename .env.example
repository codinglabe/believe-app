APP_NAME="Believe App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Local DB — the docker one-liner in CLAUDE.md gives you exactly these creds on 33066.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=33066
DB_DATABASE=believe
DB_USERNAME=believe
DB_PASSWORD=believe

BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# Streaming pipeline (Laravel ↔ AWS SQS/Fargate/MediaMTX ↔ YouTube)
# ----------------------------------------------------------------------------
# Two modes:
#
#   (A) Simulate mode — DEFAULT for local dev. No AWS, no SQS, no tunnel.
#       Laravel applies "starting → live" in-process when a stream is queued,
#       so the UI works end-to-end without external services. Use this if you
#       are just developing the app and don't want to touch real infra.
#
#   (B) Real pipeline — flip STREAMING_SIMULATE_WORKER=false and fill in the
#       AWS block + LARAVEL_CALLBACK_TOKEN + STREAMING_CALLBACK_BASE_URL.
#       In production this is automatic. For local end-to-end testing against
#       the real AWS worker you also need a public callback URL (the AWS
#       worker has to reach your Laravel) — a cloudflared quick-tunnel is the
#       usual trick:  cloudflared tunnel --url http://localhost:8001
#       then paste the trycloudflare.com URL into STREAMING_CALLBACK_BASE_URL.
STREAMING_SIMULATE_WORKER=true

# AWS — Laravel producer IAM user (sqs:SendMessage only on the streaming queue).
# Leave blank in simulate mode.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SQS_STREAMING_QUEUE_URL=

# Shared bearer token the AWS worker uses when POSTing /api/streaming/status.
# Must match the value stored in the worker's Secrets Manager entry. Leave
# blank in simulate mode.
LARAVEL_CALLBACK_TOKEN=

# MediaMTX bridge — browser publishes WHIP here; worker pulls RTMP from the
# same host. These two are the public bridge hostname and port — they don't
# need to be reachable from your laptop in simulate mode, so leaving the
# defaults in is fine.
STREAMING_BRIDGE_HOST=stream.believeinunity.org
STREAMING_WORKER_RTMP_PULL_BASE=rtmp://stream.believeinunity.org:1935

# Public callback base for the AWS worker to POST status back to Laravel.
# In production: set to your public Laravel domain (e.g. https://believeinunity.org).
# For local end-to-end testing against real AWS: paste a cloudflared quick-tunnel URL.
# In simulate mode: leave blank — Laravel uses APP_URL.
STREAMING_CALLBACK_BASE_URL=

# Scout — disable while no Algolia/Meilisearch configured
SCOUT_DRIVER=null

# Reverb (websockets) — local defaults
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Stripe — leave blank to disable
STRIPE_KEY=
STRIPE_SECRET=
CASHIER_CURRENCY=usd

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=

# Twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Google (YouTube OAuth, GCal, etc.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# FCM (push notifications)
FCM_PROJECT_ID=
FCM_CREDENTIALS=
